# Сервер
PORT=4100
BACKEND_PORT=4100
FRONTEND_PORT=5173
CORS_ORIGIN=http://localhost:5173

# Токены входа. В боевой среде обязательно заменить.
JWT_SECRET=change-me-use-long-random-value

# Эта учётная запись создаётся или назначается главным администратором.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# Закрытая документация API: http://localhost:4100/api/docs
SWAGGER_USER=docs
SWAGGER_PASSWORD=change-me

# База данных PostgreSQL в отдельном контейнере.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=questionnaire_runner
POSTGRES_USER=questionnaire
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://questionnaire:change-me@localhost:5432/questionnaire_runner

# Веб-интерфейс управления PostgreSQL: http://localhost:5050
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@k-service44.ru
PGADMIN_DEFAULT_PASSWORD=change-me
